# Server
PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=fixmycampus_db
DB_USER=fixmycampus_app
DB_PASS=your_db_password

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your_refresh_secret_change_this
REFRESH_TOKEN_EXPIRES_IN=7d

# Nodemailer (Gmail SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_university_gmail@gmail.com
MAIL_PASS=your_gmail_app_password
MAIL_FROM="Fix My Campus <noreply@fixmycampus.edu>"

# OTP
OTP_EXPIRY_MINUTES=10

# Firebase Admin
FIREBASE_SERVICE_ACCOUNT_PATH=./config/your-service-account-file.json
FIREBASE_DATABASE_URL=https://your-project-id.firebaseio.com

# Frontend
CLIENT_URL=http://localhost:5173

# Optional Redis (for rate limiting / caching)
REDIS_URL=redis://localhost:6379

# CORS origin (comma-separated allowed origins)
CORS_ORIGIN=http://localhost:5173

# Public API URL (used by Swagger server entry)
API_URL=http://localhost:5000
