{
  "env": {
    "node": true,
    "es2021": true
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": "latest"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],
    "no-console": "off"
  },
  "overrides": [
    {
      "files": ["**/*.test.js", "**/*.spec.js", "**/tests/**/*.js"],
      "env": {
        "jest": true
      },
      "plugins": ["jest"],
      "extends": ["eslint:recommended", "plugin:jest/recommended"],
      "rules": {
        "no-unused-vars": ["warn", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],
        "no-console": "off"
      }
    }
  ]
}